#!/usr/bin/env bash
# install: Orchestrator for setting up the environment.

set -e

# Setup base path
DOTFILES_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DOTFILES_ROOT"

echo "🎯 Environment Orchestrator"

# 1. Create Symlinks
./scripts/link-dotfiles

# 2. Package Installation
echo "🍺 Setting up Homebrew..."
if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

echo "📦 Installing packages from Brewfile..."
./scripts/install-packages

# 3. Apply settings
echo " Applying macOS settings..."
./os/macos.sh

# 4. Modules Setup
echo "🧩 Configuring Modules..."

# Node.js module
if [ -f "modules/node/install.sh" ]; then
    echo "   [NODE] Running installer..."
    ./modules/node/install.sh
fi

# VSCode module (requires code command)
if command -v code &>/dev/null; then
    echo "   [VSCODE] Configuring..."
    ./modules/vscode/install.sh
fi

echo "✨ All done! Open a new shell to enjoy your setup."
