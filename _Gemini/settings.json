{
  "ui": {
    "theme": "Atom One"
  },
  "mcpServers": {
    "notion-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer [ENCRYPTION_KEY]\", \"Notion-Version\": \"2022-06-28\"}"
      }
    },
    "notebooklm": {
      "command": "npx",
      "args": [
        "notebooklm-mcp@latest"
      ]
    },
    "github": {
      "serverUrl": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer [ENCRYPTION_KEY]"
      },
      "disabled": true
    },
    "context7": {
      "serverUrl": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "[ENCRYPTION_KEY]"
      }
    },
    "StitchMCP": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://stitch.googleapis.com/mcp",
        "--header",
        "X-Goog-Api-Key: [ENCRYPTION_KEY]"
      ],
      "env": {}
    }
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  }
}